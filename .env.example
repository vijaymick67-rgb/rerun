VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only — used by api/tmdb/[...path].js. Do NOT prefix with VITE_,
# that would bundle it into the client and expose it in the browser.
# Set this in Vercel's project environment variables, not in a client .env.
TMDB_API_KEY=

# Server-only; used by api/news.js and never exposed to the browser.
GNEWS_API_KEY=

# Native Web Push (see docs/web-push.md). Generate a VAPID key pair once with
# `npx web-push generate-vapid-keys` and set these in Vercel's project
# environment variables — never commit real keys.

# Public — safe to expose in the client bundle, used to create the browser's
# PushSubscription.
VITE_VAPID_PUBLIC_KEY=

# Server-only — signs push requests. Do NOT prefix with VITE_; must never
# reach the browser.
VAPID_PRIVATE_KEY=
# Server-only — a contact URI (mailto: or https:) required by the Web Push
# protocol so push services can reach you about a misbehaving sender.
VAPID_SUBJECT=

# Server-only — used by api/push/*.js to read/write push_subscriptions,
# which is locked down (RLS revokes all access from anon/authenticated).
# The anon key cannot reach that table by design; this is required for
# subscribe/unsubscribe/test-send to function. Do NOT prefix with VITE_.
#
# Also required (set locally, never in CI) to run
# scripts/cleanup-unaired-watched.js by hand — see the comment at the top of
# that file. Once owner-only RLS is applied, the anon key can no longer
# read/write tracked_shows or watched_episodes at all, so that script needs
# this key instead. Bypasses RLS entirely — never commit it, never add it to
# a GitHub Actions secret.
SUPABASE_SERVICE_ROLE_KEY=
